        .segment "CODE"

start:  lda #$93         ; Clear screen
        jsr $ffd2

        ldx #$00
prtloop:
        lda msg,x
        beq forever
        sta $0400,x      ; Top-left screen RAM
        inx
        cpx #$0d
        bne prtloop

forever:
        jmp forever

msg:    .byte $48,$45,$4c,$4c,$4f,$20,$57,$4f  ; HELLO WO
        .byte $52,$4c,$44,$00                    ; RLD\0
